# ── Text-to-SQL Generator — API Keys Template ────────────────────────────────
# 1. Copy this file and rename it to: .env
# 2. Fill in your actual values
# 3. NEVER commit your .env file to GitHub (it's in .gitignore)
# 4. You can also enter keys directly in the app UI — no file editing needed

# ── Startup provider: azure | openrouter | ollama ─────────────────────────────
LLM_PROVIDER=azure

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
# Get from: https://portal.azure.com → Azure OpenAI → Keys and Endpoint
AZURE_API_KEY=your_azure_api_key_here
AZURE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_MODEL=gpt-4o
AZURE_VERSION=2024-12-01-preview

# ── OpenRouter (free + 100+ paid models) ──────────────────────────────────────
# Get free key from: https://openrouter.ai/keys
# Free models work with anonymous quota even without a key
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# ── Ollama (100% local, no key needed) ────────────────────────────────────────
# Install from: https://ollama.ai — then run: ollama serve
OLLAMA_URL=http://localhost:11434
